# ===============================
# Database Configuration
# ===============================
DB_DRIVER=sqlite
SQLITE_PATH=sems.db

# (Optional for PostgreSQL/MySQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sems
DB_USER=sems_user
DB_PASSWORD=sems_pass

# ===============================
# Energy Settings
# ===============================
TARIFF_RATE=8.5

# ===============================
# LSTM Settings
# ===============================
LSTM_LOOKBACK_HOURS=72
LSTM_BATCH_SIZE=32
LSTM_EPOCHS=50

# ===============================
# Prophet Settings
# ===============================
PROPHET_RESOLUTION_H=1

# ===============================
# Model Paths
# ===============================
LSTM_MODEL_PATH=models/lstm_model.h5
LSTM_SCALER_PATH=models/lstm_scaler.pkl

# ===============================
# App Settings
# ===============================
LOG_LEVEL=INFO
DEBUG=False
APP_NAME=SEMS Dashboard