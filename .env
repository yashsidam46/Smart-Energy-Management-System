# .env

# DB settings (choose one driver)
DB_DRIVER=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sems
DB_USER=sems_user
DB_PASSWORD=sems_pass

# DB file path (SQLite only)
SQLITE_PATH=sems.db

# Tariff in INR per kWh
TARIFF_RATE=8.5

# LSTM steps and batch size
LSTM_LOOKBACK_HOURS=72
LSTM_BATCH_SIZE=32
LSTM_EPOCHS=50

# Prophet fallback (in hours)
PROPHET_RESOLUTION_H=1

# App settings
LOG_LEVEL=INFO